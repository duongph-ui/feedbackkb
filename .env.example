# FeedbackKB config — copy to .env, fill values. NO real secrets here (public repo §6.5).
# This API is the ONLY thing that talks to the DB. Consumers authenticate with an
# app_key (issued by `register`) and never get a Postgres grant. Keep DATABASE_URL
# server-side only.

# --- Database (Step 1) ---
# Dedicated DB on the Clevai cluster. Schema is `fbk` (pinned via search_path by the
# pool). Real creds come from the ops vault, NOT this file.
DATABASE_URL=postgresql://<db_user>:<db_password>@postgres.clevai.vn:5432/fna

# Connection pool — hard ceiling on slots we hold on the SHARED cluster (don't starve FPA).
DB_POOL_MIN=1
DB_POOL_MAX=5

# --- Adapters (Step 3) — choose impl per concern ---
FEEDBACKKB_STORAGE=gcs         # local | gcs | s3
FEEDBACKKB_SEARCH=keyword      # keyword | pgvector | sepo
FEEDBACKKB_AUTH=appkey         # none | appkey | jwt  (appkey = clients need no DB grant)
FEEDBACKKB_KNOWLEDGE=pg        # pg | sepo

# --- Zero-admin onboarding (optional) ---
# Make systems exist WITHOUT an admin `register` call. Pair with FEEDBACKKB_AUTH=none
# so consumers need nothing at all.
#   seed: ops sets these once; upserted at startup (keyless).
FEEDBACKKB_SEED_SYSTEMS=        # e.g. "FPS:Payment System,FPA:Analytics"
#   open-register: auto-create unknown system on first feedback (trust-on-first-use).
#   INTERNAL/TRUSTED networks only — leave false on public-facing APIs.
FEEDBACKKB_OPEN_REGISTER=false  # false | true

# --- CORS (widget runs on the CONSUMER app's origin, not this server) ---
# Comma-separated allowed origins. Empty = "*" (any origin; ok for anonymous submit).
# Tighten to real app origins once auth=appkey origin-lock lands.
FEEDBACKKB_CORS_ORIGINS=        # e.g. "https://fpa.mikai.tech,https://app.clevai.vn"

# --- Auth (Step 6) ---
FPA_JWT_SECRET=                # HS256 secret for app-host JWT (leave blank for auth=none)

# --- Storage (Step 7) ---
SIGNED_URL_TTL=300             # seconds
GCS_BUCKET=
S3_BUCKET=

# --- Attachment scan (Step 8) ---
FEEDBACKKB_SCAN=off            # clamav | off

# --- Anti-abuse (Step 10) ---
FEEDBACKKB_CAPTCHA=off         # turnstile | off
REDIS_URL=

# --- Retention (Step 8/20) ---
ATTACHMENT_RETENTION_DAYS=90

# --- Semantic / AI (Phase 7, AP P5) — OFF by default; P1-P4 run on FTS+hash ---
FEEDBACKKB_EMBED=none          # none | openai | local
EMBED_DIM=1536                 # must match the model (openai 3-small=1536, MiniLM=384)
EMBED_MODEL=                   # override model id (optional)
OPENAI_API_KEY=                # only when FEEDBACKKB_EMBED=openai
FIXABILITY_MIN=0.6             # auto-advance triage->analyze when score >= this
